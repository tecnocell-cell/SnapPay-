# ============================================
# ARQUIVO: .env.homolog.example
# Copiar para .env.homolog e preencher valores reais
# NUNCA commitar .env.homolog no git!
# ============================================

# Ambiente
NODE_ENV=production
PORT=3001

# Banco de Dados
DB_HOST=localhost          # ou 'postgres' se usando Docker
DB_PORT=5432
DB_NAME=snappay_homolog
DB_USER=snappay_homolog_user
DB_PASSWORD=MUDE_PARA_SENHA_FORTE_AQUI
DB_DIALECT=postgres

# URLs
API_URL=https://homolog.seudominio.com.br
FRONTEND_URL=https://homolog.seudominio.com.br

# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/snappay

# Fiscal (deixar MOCK enquanto não tiver credenciais reais)
FISCAL_PROVIDER=MOCK
# Quando receber credenciais, mudar para:
# FISCAL_PROVIDER=FOCUS_NFE
# FISCAL_TOKEN=seu_token_focus_nfe
# FISCAL_CSC=seu_csc_sefaz
# FISCAL_ENVIRONMENT=homologacao

# JWT
JWT_SECRET=gere_uma_string_aleatoria_forte_32_caracteres
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://homolog.seudominio.com.br

# Backup
BACKUP_DIR=/backup/snappay_homolog
BACKUP_RETENTION_DAYS=7
